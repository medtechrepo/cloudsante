# CloudSanté - Frontend Web Server
# Serveur Nginx pour application médicale
# Version 1.19

FROM nginx:1.19

# Copie de l'application frontend
COPY frontend/ /usr/share/nginx/html/

# Configuration Nginx
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Exposition du port HTTP
EXPOSE 80

# Note: Aucun port HTTPS activé (port 443)
